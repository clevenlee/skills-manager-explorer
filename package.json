{
  "name": "skills-manager-explorer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "bunx --bun concurrently --kill-others --names web,server --prefix-colors blue,green \"bun run dev:web\" \"bun run dev:server\"",
    "dev:web": "bunx --bun vite --host 127.0.0.1",
    "dev:server": "bun --watch src/server/index.ts",
    "build": "bun run build:web && bun run assets:embed && bun run build:server",
    "build:web": "bunx --bun vite build",
    "build:server": "bun build src/server/index.ts --outdir dist/server --target bun",
    "assets:embed": "bun scripts/embed-static-assets.ts",
    "start": "bun src/server/index.ts",
    "package": "bun run build && bun scripts/package.ts",
    "lint": "bunx --bun eslint .",
    "format": "bunx --bun prettier --write .",
    "format:check": "bunx --bun prettier --check .",
    "typecheck": "bunx --bun vue-tsc --noEmit",
    "test": "bun test tests",
    "test:coverage": "bun test --coverage tests",
    "test:e2e": "bunx --bun playwright test",
    "openapi:generate": "bun scripts/generate-openapi.ts",
    "openapi:lint": "bunx --bun redocly lint docs/modules/skills-manager-explorer/openapi/skills-manager-explorer-local-openapi.yaml",
    "openapi:check": "bun scripts/verify-openapi-drift.ts",
    "mock": "bunx --bun prism mock docs/modules/skills-manager-explorer/openapi/skills-manager-explorer-local-openapi.yaml --host 127.0.0.1 --port 4010",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run openapi:check && bun run openapi:lint && bun run build"
  },
  "dependencies": {
    "@ant-design/icons-vue": "7.0.1",
    "@hono/zod-openapi": "1.5.1",
    "ant-design-vue": "4.2.6",
    "hono": "4.12.30",
    "vue": "3.5.40",
    "vue-i18n": "^9",
    "vue-router": "5.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@redocly/cli": "2.39.0",
    "@stoplight/prism-cli": "5.15.11",
    "@types/bun": "1.3.14",
    "@vitejs/plugin-vue": "6.0.8",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-vue": "10.9.2",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.7",
    "yaml": "2.9.0"
  }
}
